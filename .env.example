# URL of the client application (used for CORS and redirects for example)
CLIENT_URL=http://localhost:5173

# Base URL of the API
SERVER_URL=http://localhost:8000

# The GitHub organization and repository used to fork from and to create pull requests at
# Should be changed to a fork of the main CEOS ARD repository when developing
CEOS_ARD_ORG=ceos-org
CEOS_ARD_REPO=ceos-ard

# GitHub OAuth (Required for workspace features)
# GitHub authentication is REQUIRED for all workspace-related operations
# Workspaces are exclusively available to GitHub users
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub service token for cron jobs (Required for automated tasks)
GITHUB_SERVICE_TOKEN=your_github_service_token_here

# GitHub service token expiration date (REQUIRED)
# Format: YYYY-MM-DD (e.g., 2026-12-31)
# Alerts sent at 14 days, 7 days, and when expired
GITHUB_SERVICE_TOKEN_EXPIRES_AT=

# Google OAuth (Optional - for future features)
# Currently, Google users do not have access to workspace features
# This is reserved for potential future non-workspace functionality
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate a secure random string for SECRET_KEY
# You can use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here

# Environment (development, production, staging)
ENVIRONMENT=development

# Database URL (Using SQLite for development)
DATABASE_URL=sqlite:///./ceos_ard_server.db

# ============================================================================
# Email Alert Configuration (Optional)
# ============================================================================
# Configure SMTP for token expiry alerts (optional - logs only if not configured)

ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=ceos-ard-server@example.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
