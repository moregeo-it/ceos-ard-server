# Database Configuration
# SQLite database (no installation required - built into Python)
# Format: sqlite:///./database_name.db (relative path)
# Format: sqlite:////absolute/path/to/database.db (absolute path)
DATABASE_URL=sqlite:///./ceos_ard_server.db

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Security
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256

# Application URLs
LOGOUT_REDIRECT=http://localhost:3000
CALLBACK_BASE_URI=http://localhost:8000
CORS_ORIGIN_CLIENT=http://localhost:3000
AUTH_SUCCESS_CLIENT_REDIRECT=http://localhost:3000/auth/callback

# Environment
ENVIRONMENT=development

# CEOS-ARD Repository Settings
CEOS_ARD_OWNER=ceos-org
CEOS_ARD_REPO=ceos-ard
CEOS_ARD_MAIN_BRANCH=main

# Workspaces
WORKSPACES_ROOT=workspaces

# PFS Default Configuration
# Default version for new PFS documents
PFS_DEFAULT_VERSION=1.0-draft

# Default introduction sections for new PFS documents (comma-separated)
# These can be customized based on organizational requirements
PFS_DEFAULT_INTRODUCTION=what-are-ceos-ard-products,when-is-a-product-ceos-ard,difference-threshold-goal
