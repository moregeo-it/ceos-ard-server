# GitHub OAuth (Required for workspace features)
# GitHub authentication is REQUIRED for all workspace-related operations
# Workspaces are exclusively available to GitHub users
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth Configuration
# These are typically not changed unless using GitHub Enterprise
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize

# Google OAuth (Optional - for future features)
# Currently, Google users do not have access to workspace features
# This is reserved for potential future non-workspace functionality
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth Configuration
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration

# Application URLs
# Callback URL for OAuth providers
CALLBACK_BASE_URI=http://localhost:8000/auth/callback

# Client application URL (for CORS)
CORS_ORIGIN_CLIENT=http://localhost:5173

# Security Configuration
# Generate a secure random string for SECRET_KEY
# You can use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256

# Environment (development, production, staging)
ENVIRONMENT=development

# Redirect URLs
# Where to redirect after logout
LOGOUT_REDIRECT=http://localhost:5173

# Where to redirect after successful authentication
AUTH_SUCCESS_CLIENT_REDIRECT=http://localhost:5173/auth/callback

# Database Configuration
# SQLite database (no installation required - built into Python)
# Format: sqlite:///./database_name.db (relative path)
# Format: sqlite:////absolute/path/to/database.db (absolute path)
DATABASE_URL=sqlite:///./ceos_ard_server.db

# PFS Default Configuration
# Default version for new PFS documents
PFS_DEFAULT_VERSION=1.0-draft

# Default introduction sections for new PFS documents (comma-separated)
# These can be customized based on organizational requirements
PFS_DEFAULT_INTRODUCTION=what-are-ceos-ard-products,when-is-a-product-ceos-ard,difference-threshold-goal
